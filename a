local cleanupListener
cleanupListener = RunService.RenderStepped:Connect(function()
    if not Shared.StaffNotifier then
        if StaffListGui then StaffListGui:Destroy() end
        if localPlayer.PlayerGui:FindFirstChild("StaffNotifierGui") then
            localPlayer.PlayerGui.StaffNotifierGui:Destroy()
        end
        
        cleanupListener:Disconnect()
        
        -- Alle anderen Verbindungen stoppen
        if Shared.Connections[key] then
            for _, c in pairs(Shared.Connections[key]) do
                pcall(function() c:Disconnect() end)
            end
            Shared.Connections[key] = {}
        end
    end
end)
table.insert(Shared.Connections[key], cleanupListener)

local pa = Players.PlayerAdded:Connect(function(plr)
    task.wait(1)
    if isStaff(plr) then
        updateStaffList()
    end
end)
table.insert(Shared.Connections[key], pa)

local pr = Players.PlayerRemoving:Connect(function(plr)
    updateStaffList()
end)
table.insert(Shared.Connections[key], pr)

task.spawn(function()
    while true do
        if not Shared.StaffNotifier then 
            break 
        end
        
        local currentStaff = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= localPlayer and isStaff(plr) then currentStaff[plr.UserId] = plr end
        end
        for userId, plr in pairs(currentStaff) do
            if not lastStaffInServer[userId] then
                showModernNotification(plr.Name .. " (Staff) joined! Disable your scripts or leave!", Color3.fromRGB(255, 0, 0))
                updateStaffList()
            end
        end
        for userId, oldPlr in pairs(lastStaffInServer) do
            if not currentStaff[userId] then
                local leftName = oldPlr and oldPlr.Name or "Staff"
                showModernNotification(leftName .. " (Staff) left. It's now safe to continue using scripts.", Color3.fromRGB(0, 200, 100))
                updateStaffList()
            end
        end
        lastStaffInServer = currentStaff
        task.wait(2)
    end
end)

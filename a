task.spawn(function()
    while true do
        if not Shared.StaffNotifier then
            break
        end
        local currentStaff = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= localPlayer and isStaff(plr) then
                currentStaff[plr.UserId] = plr
            end
        end
        for userId, plr in pairs(currentStaff) do
            if not lastStaffInServer[userId] then
                if Shared.AutoKickStaff then
                    performAutoKick(plr.Name)
                    return
                end
                showNotification(plr.Name .. " joined! (STAFF)", "danger")
                updateStaffList()
            end
        end
        for userId, oldPlr in pairs(lastStaffInServer) do
            if not currentStaff[userId] then
                local leftName = oldPlr and oldPlr.Name or "Staff"
                showNotification(leftName .. " left. Safe to continue.", "success")
                updateStaffList()
            end
        end
        lastStaffInServer = currentStaff
        task.wait(5)
    end
end)

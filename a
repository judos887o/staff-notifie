local function corner(inst, px)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, px or s(10))
    c.Parent = inst
    return c
end

local function strokeUI(inst, color, thickness, transparency)
    local st = Instance.new("UIStroke")
    st.Color = color
    st.Thickness = thickness or 1
    st.Transparency = transparency or 0
    st.Parent = inst
    return st
end

local groupId = 106259084 -- NEUE GRUPPEN ID
local minimumRank = 1
local lastStaffInServer = {}
local staffCache = setmetatable({}, {__mode = "k"})

local function isStaff(player)
    if staffCache[player] ~= nil then return staffCache[player] end
    local success, rank = pcall(function() return player:GetRankInGroup(groupId) end)
    local result = success and rank >= minimumRank
    staffCache[player] = result
    return result
end


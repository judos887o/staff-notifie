local function showNotification(text, notifType)
    local notifGui = Instance.new("ScreenGui")
    notifGui.Name = "StaffNotifierGui"
    notifGui.ResetOnSpawn = false
    notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notifGui.Parent = localPlayer:WaitForChild("PlayerGui")

    local notifW = s(340)
    local notifH = s(50)

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, notifW, 0, notifH)
    mainFrame.Position = UDim2.new(0.5, -notifW/2, 0, -notifH - s(20))
    mainFrame.BackgroundColor3 = COL.BgMain
    mainFrame.BorderSizePixel = 0
    mainFrame.ZIndex = 10
    mainFrame.Parent = notifGui
    corner(mainFrame, s(8))

    local notifStrokeColor = COL.StrokeMain
    if notifType == "danger" then notifStrokeColor = COL.Danger
    elseif notifType == "success" then notifStrokeColor = COL.Success end
    strokeUI(mainFrame, notifStrokeColor, 1, 0)

    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, s(4), 1, -s(16))
    accentBar.Position = UDim2.new(0, s(8), 0, s(8))
    accentBar.BorderSizePixel = 0
    accentBar.ZIndex = 11
    accentBar.Parent = mainFrame
    corner(accentBar, s(4))

    if notifType == "danger" then accentBar.BackgroundColor3 = COL.Danger
    elseif notifType == "success" then accentBar.BackgroundColor3 = COL.Success
    else accentBar.BackgroundColor3 = COL.StrokeMain end

    local notifText = Instance.new("TextLabel")
    notifText.Text = text
    notifText.Size = UDim2.new(1, -s(30), 1, 0)
    notifText.Position = UDim2.new(0, s(20), 0, 0)
    notifText.BackgroundTransparency = 1
    notifText.TextColor3 = COL.TextOn
    notifText.Font = Enum.Font.GothamBold
    notifText.TextSize = s(12)
    notifText.TextWrapped = true
    notifText.ZIndex = 11
    notifText.TextYAlignment = Enum.TextYAlignment.Center
    notifText.TextXAlignment = Enum.TextXAlignment.Left
    notifText.Parent = mainFrame

    local notifSound = Instance.new("Sound")
    notifSound.SoundId = CLICK_SOUND_ID
    notifSound.Volume = 0.5
    notifSound.Parent = notifGui
    notifSound:Play()

    local targetPos = UDim2.new(0.5, -notifW/2, 0, s(20))
    TweenService:Create(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetPos}):Play()

    task.delay(6, function()
        if not notifGui or not notifGui.Parent then return end
        local outPos = UDim2.new(0.5, -notifW/2, 0, -notifH - s(20))
        TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = outPos}):Play()
        task.wait(0.5)
        if notifGui then notifGui:Destroy() end
    end)
end


    icon.ImageTransparency = 1
    icon.ZIndex = 2
    icon.Parent = notificationFrame

    if notifType == "danger" then
        icon.ImageColor3 = Theme.Danger
    elseif notifType == "success" then
        icon.ImageColor3 = Theme.Success
    else
        icon.ImageColor3 = Theme.Purple
    end

    local notificationText = Instance.new("TextLabel")
    notificationText.Text = text
    notificationText.Size = UDim2.new(1, -(165 * SCALE), 1, 0)
    notificationText.Position = UDim2.new(0, 155 * SCALE, 0, 0)
    notificationText.BackgroundTransparency = 1
    notificationText.TextColor3 = Theme.Text
    notificationText.Font = Enum.Font.GothamBold
    notificationText.TextSize = scaleSize(14)
    notificationText.TextWrapped = true
    notificationText.ZIndex = 2
    notificationText.TextTransparency = 1
    notificationText.TextYAlignment = Enum.TextYAlignment.Center
    notificationText.TextXAlignment = Enum.TextXAlignment.Left
    notificationText.Parent = notificationFrame

    local textGrad = Instance.new("UIGradient")
    textGrad.Rotation = 0
    if notifType == "danger" then
        textGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 150, 180))
        })
    elseif notifType == "success" then
        textGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 255, 200))
        })
    else
        textGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 150, 200))
        })
    end
    textGrad.Parent = notificationText

    local notificationSound = Instance.new("Sound")
    notificationSound.SoundId = "rbxassetid://17208372272"
    notificationSound.Volume = 0.5
    notificationSound.Parent = staffNotifierGui
    notificationSound:Play()

    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local targetPos = UDim2.new(0.5, -(260 * SCALE), 0, 20 * SCALE)

    TweenService:Create(mainFrame, tweenInfo, {Position = targetPos}):Play()
    TweenService:Create(shadow, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 0.5}):Play()
    TweenService:Create(notificationFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 0.05}):Play()
    TweenService:Create(notifStroke, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {Transparency = 0}):Play()
    TweenService:Create(logo1, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {ImageTransparency = 0}):Play()
    TweenService:Create(logo2, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {ImageTransparency = 0}):Play()
    TweenService:Create(xLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
    TweenService:Create(icon, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {ImageTransparency = 0}):Play()
    TweenService:Create(notificationText, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()

    local colorPhase = 0
    local colorConnection
    colorConnection = RunService.Heartbeat:Connect(function(dt)
        if not notificationFrame.Parent then
            colorConnection:Disconnect()
            return
        end
        
        colorPhase = (colorPhase + dt * 0.8) % 1
        
        local function lerpColor(t)
            local colors = {
                Color3.fromRGB(255, 20, 147),
                Color3.fromRGB(220, 20, 60),
                Color3.fromRGB(180, 50, 255),
                Color3.fromRGB(255, 105, 180),
            }
            local index = math.floor(t * #colors) + 1
            local nextIndex = (index % #colors) + 1
            local localT = (t * #colors) % 1
            return colors[index]:Lerp(colors[nextIndex], localT)
        end
        
        local o1, o2, o3 = colorPhase, (colorPhase + 0.33) % 1, (colorPhase + 0.66) % 1
        
        strokeGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, lerpColor(o1)),
            ColorSequenceKeypoint.new(0.5, lerpColor(o2)),
            ColorSequenceKeypoint.new(1, lerpColor(o3))
        })
        
        xGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, lerpColor(o2)),
            ColorSequenceKeypoint.new(1, lerpColor(o3))
        })
    end)

    task.delay(8, function()
        if not staffNotifierGui or not staffNotifierGui.Parent then return end
        
        local outTween = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        local outPos = UDim2.new(0.5, -(260 * SCALE), 0, -(80 * SCALE))
        
        TweenService:Create(mainFrame, outTween, {Position = outPos}):Play()
        TweenService:Create(shadow, outTween, {BackgroundTransparency = 1}):Play()
        TweenService:Create(notificationFrame, outTween, {BackgroundTransparency = 1}):Play()
        TweenService:Create(notifStroke, outTween, {Transparency = 1}):Play()
        TweenService:Create(logo1, outTween, {ImageTransparency = 1}):Play()
        TweenService:Create(logo2, outTween, {ImageTransparency = 1}):Play()
        TweenService:Create(xLabel, outTween, {TextTransparency = 1}):Play()
        TweenService:Create(icon, outTween, {ImageTransparency = 1}):Play()
        TweenService:Create(notificationText, outTween, {TextTransparency = 1}):Play()
        
        task.wait(0.5)
        colorConnection:Disconnect()
        if staffNotifierGui then staffNotifierGui:Destroy() end
    end)
end

